# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Python (scripts + tests)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
.venv-*/
venv/
*.egg-info/
# uv writes a lockfile when `uv run`/`uv pip` touches the tree; the repo uses
# ephemeral uvx (no pinned project), so the lockfile is a local byproduct.
uv.lock

# User-local agami state should NEVER appear in this repo
.agami/

# Claude Code per-user settings (permissions allowlist, etc.)
# .claude/settings.json is committed (shared defaults).
# .claude/settings.local.json is per-user and must NOT be committed.
.claude/settings.local.json

# Test artifacts
tests/integration/.tmp/
tests/integration/*.log

# Built fixtures — sources are checked in (sqlite-shop-init.sql); the binary
# .db is built locally by the smoke-test harness.
tests/integration/fixtures/*.db

# Sample database — seed.sql + the prebuilt model/ are committed; the binary
# .db is built locally (build_sample.py) and never committed.
plugins/agami/samples/store/*.db

# Dotenv (only for local dev, never committed)
.env
.env.local

# Host-side plugin markers (created by Claude Code when a symlinked plugin is detected)
.orphaned_at

# Scratch blog drafts (authored in other sessions; not part of the plugin)
blog/

# curate op-log written when editing the committed sample model in place — never commit
plugins/agami/samples/store/model/curation_log.jsonl

# Python tooling artifacts
.coverage
coverage.xml
htmlcov/
.ruff_cache/

# Generated UI previews (regenerate with render_previews.py)
previews/
