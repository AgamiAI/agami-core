#!/usr/bin/env bash
# sm — run the agami semantic-model CLI with a model-capable Python.
#
# The semantic_model package needs pydantic + sqlglot + pyyaml. The interpreter
# agami uses for execution (psql tier, or the python-driver tier) may not have
# them, and bare `python3` on PATH often won't either. This wrapper is the ONE
# place that resolves a usable interpreter, ensures the deps are present, and runs
# the CLI — so every skill just calls `bash "$AGAMI_PLUGIN_ROOT/scripts/sm" <cmd>`
# and never has to think about interpreters or sys.path.
#
# Interpreter resolution order:
#   $AGAMI_PYTHON               (explicit override)
#   <artifacts_dir>/local/.config tool_paths.python3   (agami's configured interpreter)
#   python3 / python on PATH
#
# Deps: if pydantic/sqlglot/pyyaml aren't importable, install them once into that
# interpreter (user site first, then plain) and tell the user. Idempotent.
#
# Usage:  bash scripts/sm <cli-subcommand> [args...]
#   e.g.  bash scripts/sm areas   ~/agami-artifacts/main
#         bash scripts/sm prepare ~/agami-artifacts/main --area sales --sql "SELECT 1"
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# agami-core was relocated into an installable package (OCR-028). The CLI runs as
# `python -m semantic_model.cli` against the *installed* package; we install it (with the
# model extra, which brings pydantic/sqlglot/pyyaml) on demand below.
PKG_DIR="$(cd "$SCRIPT_DIR/../../../packages/agami-core" && pwd)"

resolve_python() {
  if [ -n "${AGAMI_PYTHON:-}" ]; then echo "$AGAMI_PYTHON"; return; fi
  # configured interpreter from <artifacts_dir>/local/.config (best-effort), with a
  # legacy ~/.agami/.config fallback during the transition
  local cfg
  cfg="$(python3 - <<'PY' 2>/dev/null || true
import json, os, pathlib
art = os.environ.get("AGAMI_ARTIFACTS_DIR")
if not art:
    ptr = pathlib.Path("~/.config/agami/path").expanduser()
    try:
        art = ptr.read_text().strip() if ptr.exists() else ""
    except OSError:
        art = ""
art = art or str(pathlib.Path("~/agami-artifacts").expanduser())
p = pathlib.Path(os.path.expanduser(art)) / "local" / ".config"
if not p.exists():
    legacy = pathlib.Path("~/.agami/.config").expanduser()
    p = legacy if legacy.exists() else p
try:
    print(json.loads(p.read_text()).get("tool_paths", {}).get("python3") or "")
except Exception:
    print("")
PY
)"
  if [ -n "$cfg" ] && [ -x "$cfg" ]; then echo "$cfg"; return; fi
  command -v python3 || command -v python || true
}

PY="$(resolve_python)"
if [ -z "$PY" ]; then
  echo "agami: no Python interpreter found (tried \$AGAMI_PYTHON, <artifacts_dir>/local/.config, PATH)." >&2
  exit 3
fi

# Ensure the agami-core package + its model deps are importable in $PY; install once if not.
# (A broken/moved editable install fails this import and self-heals via the reinstall — which
# matters because the plugin's cache dir is version-pinned and moves on every update.)
if ! "$PY" -c 'import semantic_model, pydantic, sqlglot, yaml' 2>/dev/null; then
  echo "agami: installing agami-core (semantic model) into $PY …" >&2
  if ! "$PY" -m pip install --user -q -e "$PKG_DIR[model]" >&2 2>/dev/null; then
    if ! "$PY" -m pip install -q -e "$PKG_DIR[model]" >&2; then
      echo "agami: couldn't install agami-core into $PY." >&2
      echo "       Run:  $PY -m pip install -e \"$PKG_DIR[model]\"" >&2
      echo "       Or point agami at a Python that has it:  export AGAMI_PYTHON=/path/to/python" >&2
      exit 3
    fi
  fi
fi

exec "$PY" -m semantic_model.cli "$@"
