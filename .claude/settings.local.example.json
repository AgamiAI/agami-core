{
  "_comment": [
    "Recommended permission allowlist for agami. Copy this file to",
    ".claude/settings.local.json (in the project root, or in ~/.claude/ for global",
    "scope) so Claude Code stops re-prompting for the same Bash patterns the",
    "agami skills run constantly.",
    "",
    "Match patterns are exact-prefix; so `Bash(python3 .../scripts/execute_sql.py)`",
    "approves any invocation of that script regardless of arguments. The shell-",
    "expanded forms below cover psql / mysql / snowsql with auth files, plus the",
    "validator and chart-template render paths.",
    "",
    "If a command isn't on this list, Claude Code will prompt the user — that's",
    "the safe default. Add patterns conservatively as you encounter friction.",
    "",
    "REMOVE this `_comment` array before committing the resulting",
    ".claude/settings.local.json (which is gitignored anyway)."
  ],
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/.agami)",
      "Bash(chmod 700 ~/.agami)",
      "Bash(chmod 600 ~/.agami/*)",
      "Bash(stat -f '%A' ~/.agami/credentials)",
      "Bash(stat -c '%a' ~/.agami/credentials)",
      "Bash(ls -ld ~/.agami)",
      "Bash(ls -l ~/.agami/credentials)",
      "Bash(cat ~/.agami/.config)",
      "Bash(test -f ~/.agami/credentials)",
      "Bash(test -f ~/.agami/USER_MEMORY.md)",
      "Bash(which psql)",
      "Bash(which mysql)",
      "Bash(which sqlite3)",
      "Bash(which duckdb)",
      "Bash(which snowsql)",
      "Bash(which python3)",
      "Bash(python3 -c 'import psycopg2')",
      "Bash(python3 -c 'import pymysql')",
      "Bash(python3 -c 'import snowflake.connector')",
      "Bash(python3 ~/.claude/plugins/litebi/agami/scripts/execute_sql.py)",
      "Bash(python3 ~/.claude/plugins/litebi/agami/scripts/setup_pgauth.py)",
      "Bash(python3 ~/.claude/plugins/litebi/agami/scripts/validate_semantic_model.py)",
      "Bash(python3 ~/.claude/plugins/litebi/agami/scripts/build_duckdb_attach.py)",
      "Bash(python3 ~/.claude/plugins/litebi/agami/scripts/sample_render_chart.py)",
      "Bash(open ~/.agami/charts/*.html)",
      "Bash(date -u)",
      "Bash(date +%s)",
      "Bash(uuidgen)",
      "Bash(echo agami-plan-probe)",
      "Read(/Users/*/.agami/**)",
      "Write(/Users/*/.agami/**)",
      "Edit(/Users/*/.agami/**)"
    ]
  }
}
