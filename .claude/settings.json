{
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/agami-artifacts)",
      "Bash(chmod 755 ~/agami-artifacts)",
      "Bash(ls -ld ~/agami-artifacts)",
      "Bash(test -f ~/agami-artifacts/USER_MEMORY.md)",
      "Bash(which psql)",
      "Bash(which mysql)",
      "Bash(which sqlite3)",
      "Bash(which duckdb)",
      "Bash(which snowsql)",
      "Bash(which python3)",
      "Bash(python3 -c 'import psycopg2')",
      "Bash(python3 -c 'import pymysql')",
      "Bash(python3 -c 'import snowflake.connector')",
      "Bash(python3 ~/.claude/plugins/cache/agami/agami-core/*/scripts/execute_sql.py)",
      "Bash(python3 ~/.claude/plugins/cache/agami/agami-core/*/scripts/setup_pgauth.py)",
      "Bash(python3 ~/.claude/plugins/cache/agami/agami-core/*/scripts/validate_semantic_model.py)",
      "Bash(python3 ~/.claude/plugins/cache/agami/agami-core/*/scripts/build_duckdb_attach.py)",
      "Bash(python3 ~/.claude/plugins/cache/agami/agami-core/*/scripts/render_chart.py)",
      "Bash(open https://github.com/AgamiAI/agami-core)",
      "Bash(date -u)",
      "Bash(date +%s)",
      "Bash(uuidgen)",
      "Bash(echo agami-plan-probe)",
      "Read(/Users/*/agami-artifacts/**)",
      "Write(/Users/*/agami-artifacts/**)",
      "Edit(/Users/*/agami-artifacts/**)"
    ]
  },
  "extraKnownMarketplaces": {
    "astral": {
      "source": { "source": "github", "repo": "astral-sh/claude-code-plugins" }
    },
    "claude-plugins-official": {
      "source": { "source": "github", "repo": "anthropics/claude-code" }
    }
  },
  "enabledPlugins": {
    "astral@astral": true,
    "code-review@claude-plugins-official": true
  }
}
